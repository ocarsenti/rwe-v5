[Unit]
Description=RWE-v5 Epistemic Engine API (uvicorn)
After=network.target

[Service]
Type=simple
User=olive
WorkingDirectory=/home/olive/rwe-v5
EnvironmentFile=/home/olive/rwe-v5/.env
ExecStart=/usr/bin/python3 /home/olive/.local/bin/uvicorn api:app --host 0.0.0.0 --port 8095
Restart=always
RestartSec=5
StandardOutput=append:/home/olive/rwe-v5/api_server.log
StandardError=append:/home/olive/rwe-v5/api_server.log

[Install]
WantedBy=multi-user.target
